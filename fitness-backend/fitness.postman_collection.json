{
  "info": {
    "name": "ForgeTrack API Collection",
    "_postman_id": "cleaned-expanded",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8084" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "activityId", "value": "" }
  ],
  "item": [

    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@gmail.com\",\n  \"password\": \"123456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/auth/login"
          }
        }
      ]
    },

    {
      "name": "User Service",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\":\"Hardik\",\n  \"lastName\":\"Gupta\",\n  \"email\":\"user@gmail.com\",\n  \"password\":\"123456\"\n}"
            },
            "url": "{{base_url}}/api/users/register"
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/users/{{userId}}"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\":\"Updated\",\n  \"lastName\":\"User\"\n}"
            },
            "url": "{{base_url}}/api/users/{{userId}}"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/users/{{userId}}"
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/users/all"
          }
        },
        {
          "name": "Update Role",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/users/{{userId}}/role?role=ROLE_ADMIN"
          }
        }
      ]
    },

    {
      "name": "Activity Service",
      "item": [
        {
          "name": "Create Activity",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\":\"RUNNING\",\n  \"duration\":30,\n  \"caloriesBurned\":200,\n  \"startTime\":\"2026-04-23T10:00:00\"\n}"
            },
            "url": "{{base_url}}/api/activities"
          }
        },
        {
          "name": "Get User Activities",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/activities/user/{{userId}}"
          }
        },
        {
          "name": "Update Activity",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/activities/{{activityId}}"
          }
        },
        {
          "name": "Delete Activity",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/activities/{{activityId}}"
          }
        },
        {
          "name": "Get All Activities",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/activities/all"
          }
        }
      ]
    },

    {
      "name": "AI Service",
      "item": [
        {
          "name": "Chat",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"How to improve stamina?\"\n}"
            },
            "url": "{{base_url}}/api/ai/chat"
          }
        },
        {
          "name": "Get Recommendations by User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/recommendations/user/{{userId}}"
          }
        },
        {
          "name": "Get Recommendations by Activity",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/recommendations/activity/{{activityId}}"
          }
        }
      ]
    }

  ]
}